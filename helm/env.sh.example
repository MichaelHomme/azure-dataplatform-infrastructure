# ---------------------------------------------------------
# Environment Variables for Airflow on AKS Deployment
# ---------------------------------------------------------
# Copy this file to env.sh and fill in your values from Terraform output.
# DO NOT commit env.sh to version control.
# ---------------------------------------------------------

# Azure Resource Group
export RESOURCE_GROUP_NAME="rg-azure-dataplatform-mvp"
export LOCATION="norwayeast"

# Managed Identity
export IDENTITY_NAME="airflow-identity"
export IDENTITY_NAME_CLIENT_ID="<airflow_identity_client_id from terraform output>"
export IDENTITY_NAME_PRINCIPAL_ID="<airflow_identity_principal_id from terraform output>"

# Azure Container Registry
export ACR_REGISTRY="<acr_name from terraform output>"

# Key Vault
export KEYVAULT_NAME="<keyvault_name from terraform output>"
export KEYVAULTURL="<keyvault_vault_uri from terraform output>"
export AIRFLOW_GIT_PAT_SECRET_NAME="airflow-git-pat"

# AKS
export CLUSTER_NAME="aks-dataplatform-mvp"
export OIDC_URL="<aks_oidc_issuer_url from terraform output>"

# Storage Account
export AKS_AIRFLOW_LOGS_STORAGE_ACCOUNT_NAME="<storage_account_name from terraform output>"
export AKS_AIRFLOW_LOGS_STORAGE_CONTAINER_NAME="airflow-logs"
export AKS_AIRFLOW_LOGS_STORAGE_SECRET_NAME="storage-account-credentials"

# Airflow / Kubernetes
export AKS_AIRFLOW_NAMESPACE="airflow"
export SERVICE_ACCOUNT_NAME="airflow"

# Tenant ID (auto-populated)
export TENANT_ID="$(az account show --query tenantId -o tsv)"
